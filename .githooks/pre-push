#!/bin/sh
# Pre-push shift-left gate. Runs the full deterministic gate suite so a red tree
# never reaches CI (green here == green in CI). Enabled per-clone via
# `core.hooksPath = .githooks`; run `node scripts/setup-hooks.mjs` once after
# cloning.
#
# Emergency bypass (use sparingly): git push --no-verify
#
# CI remains the real backstop — this hook only enforces locally and can be bypassed.

echo "pre-push: running scripts/run-gates.mjs (bypass with 'git push --no-verify') ..."
node scripts/run-gates.mjs
status=$?
if [ "$status" -ne 0 ]; then
  echo "pre-push: gates FAILED — push blocked. Fix the gate above, or 'git push --no-verify' to override." 1>&2
  exit 1
fi
exit 0
